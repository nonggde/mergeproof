{
  "name": "mergeproof",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "scripts": {
		"check": "tsc --noEmit && tsc -p test/tsconfig.json --noEmit && node --check public/app.js && wrangler deploy --dry-run",
    "deploy": "wrangler deploy --minify",
    "dev": "wrangler dev --port 8787",
    "start": "wrangler dev --port 8787",
    "test": "vitest run",
    "test:watch": "vitest",
    "cf-typegen": "wrangler types --include-runtime=false"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260714.1",
    "typescript": "latest",
    "vitest": "latest",
    "wrangler": "latest"
  }
}
